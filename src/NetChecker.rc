// ----------------------------------------------------------------------------
// Context menu for ListView right-click
// ----------------------------------------------------------------------------
IDR_CONTEXT_LIST MENU
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "&Habilitar todos",      ID_CTX_ENABLE_ALL
        MENUITEM "&Deshabilitar todos",   ID_CTX_DISABLE_ALL
        MENUITEM SEPARATOR
        MENUITEM "Habilitar solo &TCP",   ID_CTX_ENABLE_TCP
        MENUITEM "Deshabilitar solo TC&P",ID_CTX_DISABLE_TCP
        MENUITEM "Habilitar solo &UDP",   ID_CTX_ENABLE_UDP
        MENUITEM "Deshabilitar solo UD&P",ID_CTX_DISABLE_UDP
    END
END

