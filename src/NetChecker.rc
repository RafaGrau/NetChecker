    CONTROL         "",IDC_CFG_TAB,"SysTabControl32",TCS_TABS|WS_CHILD|WS_VISIBLE|WS_TABSTOP|WS_CLIPSIBLINGS,7,33,476,225
    CONTROL         "",IDC_CFG_LIST,"SysListView32",LVS_REPORT|LVS_SHOWSELALWAYS|LVS_SINGLESEL|WS_CHILD|WS_VISIBLE|WS_BORDER|WS_TABSTOP,14,54,462,199
    LTEXT           "Puerto:",IDC_STATIC,7,266,30,8
    EDITTEXT        IDC_CFG_EDIT_PORT,39,264,35,12,ES_NUMBER|WS_TABSTOP
    LTEXT           "Protocolo:",IDC_STATIC,79,266,38,8
    COMBOBOX        IDC_CFG_COMBO_PROTO,120,264,45,40,CBS_DROPDOWNLIST|WS_TABSTOP
    LTEXT           "Descripción:",IDC_STATIC,170,266,46,8
    EDITTEXT        IDC_CFG_EDIT_DESC,218,264,165,12,ES_AUTOHSCROLL|WS_TABSTOP
    PUSHBUTTON      "Agregar puerto",IDC_CFG_BTN_ADD_PORT,7,281,65,14
    PUSHBUTTON      "Actualizar",IDC_CFG_BTN_UPD_PORT,76,281,55,14
    PUSHBUTTON      "Eliminar puerto",IDC_CFG_BTN_DEL_PORT,135,281,65,14
    PUSHBUTTON      "Importar CSV",IDC_CFG_BTN_IMPORT_CSV,7,316,65,14
    PUSHBUTTON      "Exportar CSV",IDC_CFG_BTN_EXPORT_CSV,76,316,65,14
    DEFPUSHBUTTON   "Aceptar",IDOK,365,316,60,14
    PUSHBUTTON      "Cancelar",IDCANCEL,430,316,55,14
