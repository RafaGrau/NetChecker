// ----------------------------------------------------------------------------
// IDD_ABOUT
// ----------------------------------------------------------------------------
IDD_ABOUT DIALOGEX 0, 0, 270, 130
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Acerca de NetChecker"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    // Fila 1: icono app + nombre + subtitulo
    ICON            IDR_MAINFRAME, IDC_STATIC, 8, 8, 32, 32
    LTEXT           "NetChecker  (x64)", IDC_STATIC, 48, 10, 210, 12
    LTEXT           "Comprobador de conectividad TCP/UDP", IDC_STATIC, 48, 24, 210, 10

    CONTROL         "", IDC_STATIC, "Static", SS_ETCHEDHORZ, 6, 44, 258, 1

    // Fila 2: icono GitHub + enlace URL
    ICON            IDI_ICON_GITHUB, IDC_STATIC, 8, 50, 16, 16
    CONTROL         "", IDC_ABOUT_LINK_GITHUB, "SysLink", WS_CHILD | WS_VISIBLE | WS_TABSTOP, 30, 52, 232, 12

    CONTROL         "", IDC_STATIC, "Static", SS_ETCHEDHORZ, 6, 70, 258, 1

    // Licencia
    LTEXT           "General Public License v3.0", IDC_STATIC, 8, 76, 254, 10

    // Iconos
    LTEXT           "Iconos:", IDC_STATIC, 8, 90, 28, 10
    CONTROL         "", IDC_ABOUT_LINK_ICONS8, "SysLink", WS_CHILD | WS_VISIBLE | WS_TABSTOP, 38, 90, 224, 12

    DEFPUSHBUTTON   "Aceptar", IDOK, 202, 110, 60, 14
END

